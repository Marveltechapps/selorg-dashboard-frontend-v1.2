# Copy this file to `.dashboard-smoke.env` and fill in values.
# `.dashboard-smoke.env` is gitignored — never commit secrets.

# Login: choose "Admin Operations" tile, then:
SUPERADMIN_EMAIL=superadmin@selorg.com
SUPERADMIN_PASSWORD=SelorgDev1!SuperAdmin

# Login: darkstore | production | warehouse | rider | vendor | finance | merch tiles — shared password:
ROLE_ACCOUNT_PASSWORD=password123

# Optional: override emails if your tenant uses different accounts
# DARKSTORE_EMAIL=darkstore@selorg.com
# PRODUCTION_EMAIL=production@selorg.com
# WAREHOUSE_EMAIL=warehouse@selorg.com
# RIDER_EMAIL=rider@selorg.com
# VENDOR_EMAIL=vendor@selorg.com
# FINANCE_EMAIL=finance@selorg.com
# MERCH_EMAIL=merch@selorg.com
