# Example nginx site for dashboard.selorg.com (static SPA + API proxy)
# Use this with .env.production where VITE_API_BASE_URL is unset (same-origin /api/v1).
# Proxy targets the Node backend on the same host as api.selorg.com (port 3333 by default).

upstream selorg_backend {
    server 127.0.0.1:3333;
    keepalive 32;
}

server {
    listen 80;
    server_name dashboard.selorg.com www.dashboard.selorg.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name dashboard.selorg.com www.dashboard.selorg.com;

    # ssl_certificate /etc/letsencrypt/live/dashboard.selorg.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/dashboard.selorg.com/privkey.pem;

    root /var/www/dashboard/build;
    index index.html;

    location /health {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Dashboard login and all REST calls (same-origin — no browser CORS)
    location /api/ {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location /socket.io/ {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /hhd-socket.io/ {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
